{
  "name": "coralite-chat",
  "private": true,
  "type": "module",
  "keywords": [
    "chat",
    "real-time",
    "messaging",
    "coralite",
    "pocketbase",
    "static-site",
    "javascript"
  ],
  "scripts": {
    "start": "node scripts/start-dev.js",
    "start:app": "cross-env NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve\" coralite-scripts dev",
    "start:services": "docker compose up -d",
    "start:tracker": "node src/server/tracker.js",
    "build": "coralite-scripts build",
    "lint:format": "eslint --cache --fix .",
    "test:server": "sirv dist --dev --port 3000",
    "test:unit": "pnpm --test",
    "test:unit:coverage": "pnpm --experimental-test-coverage --test",
    "test:e2e": "pnpm run build && pnpm exec playwright test",
    "test:e2e:ui": "pnpm run build && pnpm exec playwright test --ui",
    "setup:tts": "node ./scripts/download-tts-models.js",
    "setup:transcribe": "node ./scripts/download-transcribe-models.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@stylistic/eslint-plugin": "^5.9.0",
    "coralite": "^0.31.7",
    "coralite-scripts": "^0.31.7",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-jsdoc": "^62.8.1",
    "sirv-cli": "^3.0.1"
  },
  "dependencies": {
    "@transcribe/shout": "^1.0.7",
    "@transcribe/transcriber": "^3.0.1",
    "bittorrent-tracker": "^11.2.2",
    "bootstrap": "^5.3.8",
    "emoji-picker-element": "^1.29.1",
    "idb": "^8.0.3",
    "isomorphic-dompurify": "^3.0.0",
    "libsodium-wrappers": "^0.8.3",
    "marked": "^17.0.4",
    "node-datachannel": "^0.32.1",
    "pocketbase": "^0.26.8",
    "turndown": "^7.2.2",
    "webtorrent": "2.8.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "node-datachannel"
    ]
  }
}
