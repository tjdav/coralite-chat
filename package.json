{
  "name": "atoll-chat",
  "private": true,
  "type": "module",
  "keywords": [
    "chat",
    "real-time",
    "messaging",
    "coralite",
    "pocketbase",
    "static-site",
    "javascript"
  ],
  "scripts": {
    "start": "cross-env NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve\" coralite-scripts dev",
    "build": "coralite-scripts build",
    "test:server": "sirv dist --dev --port 3000",
    "test:unit": "pnpm --test",
    "test:unit:coverage": "pnpm --experimental-test-coverage --test",
    "test:e2e": "npm run build && pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@stylistic/eslint-plugin": "^5.9.0",
    "bootstrap": "^5.3.8",
    "coralite": "^0.28.5",
    "coralite-scripts": "^0.28.7",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "sirv-cli": "^3.0.1"
  },
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-wasm": "^18.0.0",
    "emoji-picker-element": "^1.29.1",
    "isomorphic-dompurify": "^3.0.0",
    "marked": "^17.0.4",
    "matrix-js-sdk": "^41.1.0",
    "zod": "^4.3.6"
  }
}
