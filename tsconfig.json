{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "module": "nodenext",
    "target": "es2024",
    "noEmit": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "database/pb_migrations", "tests/*"]
}
